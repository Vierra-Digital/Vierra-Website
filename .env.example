# =============================================================================
# Vierra Website — Environment variables (copy to .env and fill in values)
# =============================================================================
# cp .env.example .env
#
# Never commit .env to git.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# App URL (used for OAuth redirects, email links, tracking pixels)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-string
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Encrypts stored passwords and OAuth tokens at rest (base64-encoded 32-byte key)
ENCRYPTION_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (NextAuth sign-in + Gmail + Calendar)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Search Console site verification meta tag
GOOGLE_VERIFICATION=

# -----------------------------------------------------------------------------
# Google Analytics 4 (panel “Website Visits” chart — run: npm run connect-ga4)
# -----------------------------------------------------------------------------
# Numeric property ID (Admin → Property settings), NOT the account ID or G- measurement ID
GA4_PROPERTY_ID=
GA4_OAUTH_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Transactional email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_USER=
EMAIL_PASS=
FROM_EMAIL=business@example.com
FROM_NAME=Vierra

# -----------------------------------------------------------------------------
# Stripe (client billing / subscriptions)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# LinkedIn (optional integrations)
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
LINKEDIN_COMPANY_CLIENT_ID=
LINKEDIN_COMPANY_CLIENT_SECRET=
LINKEDIN_COMPANY_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Facebook / Google Ads (optional integrations — connect page)
# -----------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=
GOOGLEADS_CLIENT_ID=
GOOGLEADS_CLIENT_SECRET=
GOOGLEADS_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Manus AI (LinkedIn / outreach content generation)
# -----------------------------------------------------------------------------
MANUS_API_KEY=
MANUS_API_BASE_URL=https://api.manus.ai
MANUS_MODEL=manus-1
# MANUS_ENABLE_CHAT_FALLBACK=true
# MANUS_LOG_REQUESTS=false

# -----------------------------------------------------------------------------
# Answer The Public bridge (optional outreach research)
# -----------------------------------------------------------------------------
ANSWER_THE_PUBLIC_BRIDGE_URL=
ANSWER_THE_PUBLIC_BRIDGE_TOKEN=

# -----------------------------------------------------------------------------
# Deployment (set automatically on Netlify)
# -----------------------------------------------------------------------------
# NETLIFY=true
# NEXT_PUBLIC_SITE_URL=https://vierradev.com
