generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Author {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String?
  bio        String?
  blog_posts BlogPost[]

  @@map("authors")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BlogImage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mime_type   String
  filename    String?
  storage_key String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@map("blog_images")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BlogPostTag {
  post_id    String     @db.Uuid
  tag_id     String     @db.Uuid
  blog_posts BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  blog_tags  BlogTag  @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("blog_post_tags")
  @@id([post_id, tag_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BlogPostView {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String     @db.Uuid
  ip_hash    String?
  user_agent String?
  viewed_at  DateTime   @default(now()) @db.Timestamptz(6)
  blog_posts BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("blog_post_views")
  @@index([post_id], map: "idx_blog_post_views_post_id")
  @@index([viewed_at], map: "idx_blog_post_views_viewed_at")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BlogPost {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_id       String            @db.Uuid
  title           String
  slug            String            @unique
  content         String
  description     String?
  published_date  DateTime          @default(now()) @db.Timestamptz(6)
  updated_date    DateTime?         @db.Timestamptz(6)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  tag             String?
  visits          Int?              @default(0)
  blog_post_tags  BlogPostTag[]
  blog_post_views BlogPostView[]
  authors         Author           @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("blog_posts")
  @@index([author_id], map: "idx_blog_posts_author_id")
  @@index([slug], map: "idx_blog_posts_slug")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BlogTag {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String           @unique
  blog_post_tags BlogPostTag[]

  @@map("blog_tags")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ClientBilling {
  client_id                  String    @id @db.Uuid
  stripe_customer_id         String?
  stripe_card_brand          String?
  stripe_card_last4          String?
  stripe_connected           Boolean   @default(false)
  stripe_connected_at        DateTime? @db.Timestamptz(6)
  stripe_payment_method_id   String?
  stripe_subscription_id     String?
  stripe_subscription_status String?
  monthly_retainer_cents     Int?
  updated_at                 DateTime  @default(now()) @db.Timestamptz(6)
  clients                    Client   @relation(fields: [client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("client_billing")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Client {
  id                               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id                       String                @db.Uuid
  assigned_to                      String?               @db.Uuid
  name                             String
  email                            String
  business_name                    String
  is_active                        Boolean               @default(true)
  client_goal                      Int?
  language                         String                @default("en")
  theme                            String                @default("auto")
  two_factor_enabled               Boolean               @default(false)
  email_notifications              Boolean               @default(true)
  image_storage_key                String?
  image_mime_type                  String?
  created_at                       DateTime              @default(now()) @db.Timestamptz(6)
  updated_at                       DateTime              @default(now()) @db.Timestamptz(6)
  user_id                          String?               @unique @db.Uuid
  client_billing                   ClientBilling?
  users_clients_assigned_toTousers User?         @relation("clients_assigned_toTousers", fields: [assigned_to], references: [id], onUpdate: NoAction)
  companies                        Company             @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_clients_user_idTousers     User?         @relation("clients_user_idTousers", fields: [user_id], references: [id], onUpdate: NoAction)
  onboarding_sessions              OnboardingSession[]
  stored_files                     StoredFile[]

  @@map("clients")
  @@index([assigned_to], map: "idx_clients_assigned_to")
  @@index([company_id], map: "idx_clients_company_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Company {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  slug                    String                    @unique
  plan                    String                    @default("free")
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  clients                 Client[]
  company_memberships     CompanyMembership[]
  email_provider_accounts EmailProviderAccount[]
  invitations             Invitation[]
  login_attempts          LoginAttempt[]
  marketing_tracker       MarketingTracker[]
  onboarding_sessions     OnboardingSession[]
  project_boards          ProjectBoard[]
  project_tasks           ProjectTask[]
  signed_documents        SignedDocument[]
  stored_files            StoredFile[]

  @@map("companies")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CompanyMembership {
  id                                         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id                                 String        @db.Uuid
  user_id                                    String        @unique(map: "one_company_per_user") @db.Uuid
  role                                       String        @default("member")
  position                                   String?
  mentor_id                                  String?       @db.Uuid
  status                                     String        @default("offline")
  strikes                                    Int           @default(0)
  joined_at                                  DateTime      @default(now()) @db.Timestamptz(6)
  companies                                  Company     @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_company_memberships_mentor_idTousers User? @relation("company_memberships_mentor_idTousers", fields: [mentor_id], references: [id], onUpdate: NoAction)
  users_company_memberships_user_idTousers   User  @relation("company_memberships_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("company_memberships")
  @@unique([company_id, user_id], map: "uq_company_user")
  @@index([company_id], map: "idx_company_memberships_company_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContactFieldVisibilitySetting {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String                   @db.Uuid
  account_id              String?                  @db.Uuid
  show_phone              Boolean                  @default(true)
  show_business           Boolean                  @default(true)
  show_website            Boolean                  @default(true)
  created_at              DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                 @default(now()) @db.Timestamptz(6)
  email_provider_accounts EmailProviderAccount? @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  users                   User             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("contact_field_visibility_settings")
  @@index([user_id], map: "idx_contact_field_visibility_user_id")
  @@unique([user_id, account_id], map: "uq_contact_field_visibility_user_account")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContactTagAssignment {
  contact_id   String       @db.Uuid
  tag_id       String       @db.Uuid
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  contacts     Contact     @relation(fields: [contact_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  contact_tags ContactTag @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("contact_tag_assignments")
  @@id([contact_id, tag_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContactTag {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String                    @db.Uuid
  name                    String
  color                   String                    @default("#701CC0")
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  contact_tag_assignments ContactTagAssignment[]
  users                   User              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("contact_tags")
  @@index([user_id], map: "idx_contact_tags_user_id")
  @@unique([user_id, name], map: "uq_contact_tags_user_name")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Contact {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String                    @db.Uuid
  account_id              String?                   @db.Uuid
  source                  String                    @default("manual")
  first_name              String?
  last_name               String?
  email                   String
  phone                   String?
  business                String?
  website                 String?
  address                 String?
  gmail_resource_name     String?
  gmail_etag              String?
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  contact_tag_assignments ContactTagAssignment[]
  email_provider_accounts EmailProviderAccount?  @relation(fields: [account_id], references: [id], onUpdate: NoAction)
  users                   User              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("contacts")
  @@index([user_id], map: "idx_contacts_user_id")
  @@unique([user_id, account_id, email], map: "uq_contacts_user_account_email")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EmailAccountSetting {
  id                             String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id                     String                         @db.Uuid
  tracking_enabled               Boolean                        @default(false)
  open_tracking_enabled          Boolean                        @default(true)
